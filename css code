:root {
  color-scheme: dark;
  --margins-header: 1rem;
  --margins-main: 5%;
  --margins-narrow: 2.5%;
  --radius-small: 4px;
  --radius-mid: 6px;
  --radius-big: 8px;
  --radius-btn: 14px;
  --radius-tag: 12px;
  --icon-content-radius: 4px;
  --icon-primary-radius: 6px;
  --icon-index-radius: 6px;
  --bg1: #000000;
  --bg2: #111515;
  --bg3: transparent;
  --bg4: #111515;
  --bg5: #000000;
  --bg6: #111515;
  --bg7: #181e1b;
  --bg8: hsl(148, 100%, 24%);
  --border1: #333B3B;
  --border2: #333B3B;
  --border3: #333B3B;
  --border4: #627A7A;
  --border-width: 1.5px;
  --shadow: none;
  --shadow-header: none;
  --shadow-buttons: none;
  --txt-size-main: 100%;
  --txt-size-work: 110%;
  --txt-header: #DAE6E1;
  --txt-header-hgl: hsl(142, 100%, 40%);
  --txt-header-hgl-h1: linear-gradient(135deg, #DAE6E1, #00cc4e);
  --txt-main: #DAE6E1;
  --txt-alt1: #DAE6E1;
  --txt-alt2: #000000;
  --link: #00ad5f;
  --link-hgl: #00cc66;
  --link-visited: #627A7A;
  --link-underline: 1px solid transparent;
  --int-btn-bg: #333B3B;
  --int-btn-border: #333B3B;
  --int-btn-txt: #DAE6E1;
  --int-btn-hgl-bg: #00ad6b;
  --int-btn-hgl-txt: #FFFFFF;
  --int-bg: #090B0B;
  --int-current-bg: #1F2626;
  --int-current-txt: #FFFFFF;
  --int-disabled-bg: #111515;
  --int-checked: #00ad56;
  --int-hgl: #00cc66;
  --int-hgl-bg: #00ad56;
  --int-hgl-txt: #FFFFFF;
  --icon1: #009172;
  --icon2: #00a682;
  --icon3: #00a685;
  --icon4: #104328;
  --icon5: #3ac7a8;
  --icon6: #24603d;
  --icon7: #306452;
  --icon8: #1f362d;
  --icon9: #82b273;
  --icon-grd: none;
  --icon-bg: #292F2F;
  --icon-id: linear-gradient(135deg, #00cc70, #007a21);
  --icon-anon: linear-gradient(135deg, #3F4B4B, #292F2F);
  --icon-coll: linear-gradient(135deg, #00cc74, #007a39);
  --icon-border1: none;
  --icon-border2: none;
  --tag-default-bg: #3F4B4B;
  --tag-fandom-bg: #99c199B3;
  --tag-warning-bg: #338333B3;
  --tag-ship-bg: #bfd8bfB3;
  --tag-platonic-bg: #99d899B3;
  --tag-character-bg: #009172B3;
  --tag-freeform-bg: #5cad5c;
  --tag-default-txt: #FFFFFFE6;
  --tag-fandom-txt: #FFFFFFE6;
  --tag-warning-txt: #FFFFFFE6;
  --tag-ship-txt: #FFFFFFE6;
  --tag-platonic-txt: #FFFFFFE6;
  --tag-character-txt: #FFFFFFE6;
  --tag-freeform-txt: #FFFFFFE6;
  --tag-border: transparent;
  --tag-hgl-bg: #00ad7f;
  --tag-hgl-txt: #FFFFFF;
  --notice-bg: #07252E;
  --success-bg: #00241A;
  --caution-bg: #261E11;
  --alert-bg: #2E0A1B;
  --notice-txt: #182f25;
  --success-txt: #00C28E;
  --caution-txt: #DCAD5B;
  --alert-txt: #EB3B7B;
  --header-icon: brightness(0) saturate(100%) invert(86%) sepia(15%) saturate(102%) hue-rotate(103deg) brightness(108%) contrast(84%);
  --header-icon-hgl: brightness(0) saturate(100%) invert(62%) sepia(23%) saturate(6137%) hue-rotate(139deg) brightness(88%) contrast(102%);
  --kudos-icon: brightness(0) saturate(100%) invert(23%) sepia(60%) saturate(2452%) hue-rotate(308deg) brightness(89%) contrast(89%);
  --lock-icon: brightness(0) saturate(100%) invert(86%) sepia(15%) saturate(102%) hue-rotate(103deg) brightness(108%) contrast(84%);
  --stats-icon: brightness(0) saturate(100%) invert(46%) sepia(13%) saturate(265%) hue-rotate(131deg) brightness(94%) contrast(92%);
  --rich-txt-content: invert(86%) sepia(15%) saturate(102%) hue-rotate(103deg) brightness(108%) contrast(84%);
}

img[src$="/images/skins/iconsets/default/icon_user.png"] {
  content: url("https://zerafinacss.github.io/ao3/icons/user-visitor-02.png");
}

#header::after {
  display: block;
  order: 3;
  width: 100%;
  height: 16.75vw;
  border-top: var(--border-width) solid var(--border2);
  background: url("https://i.pinimg.com/736x/40/e9/56/40e956a5545bd6530d36627f3c2a33e7.jpg") 
    var(--bg8) 
    no-repeat;
  background-size: cover;
  content: "";
}
